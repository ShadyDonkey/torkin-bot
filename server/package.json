{
  "name": "server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "auth:generate": "bunx @better-auth/cli generate --output ./zenstack/schemas/better-auth.zmodel --config ./lib/auth.ts",
    "bot:build": "dressed build",
    "db:migrate:create": "DATABASE_URL=postgresql://postgres:secret@localhost:5432/migrate bun zen migrate dev --create-only",
    "db:migrate:reset": "DATABASE_URL=postgresql://postgres:secret@localhost:5432/migrate bun zen migrate reset",
    "lib:tmdb:generate-schema": "openapi-typescript https://developer.themoviedb.org/openapi/tmdb-api.json -o ./lib/tmdb/schema.d.ts",
    "lib:tvdb:generate-schema": "openapi-typescript https://thetvdb.github.io/v4-api/swagger.yml -o ./lib/tvdb/schema.d.ts"
  },
  "dependencies": {
    "@date-fns/tz": "1.4.1",
    "@date-fns/utc": "2.1.1",
    "@dressed/matcher": "1.4.0",
    "@dressed/react": "1.8.4",
    "@elysiajs/cors": "1.4.1",
    "@elysiajs/static": "1.4.7",
    "@keyv/redis": "5.1.6",
    "@lukeed/ms": "2.0.2",
    "@sinclair/typebox": "0.34.48",
    "@sindresorhus/slugify": "3.0.0",
    "@tanstack/react-query": "5.90.21",
    "@zenstackhq/better-auth": "3.4.4",
    "@zenstackhq/cli": "3.4.4",
    "@zenstackhq/orm": "3.4.4",
    "await-to-js": "3.0.0",
    "better-auth": "1.5.4",
    "cacheable": "2.3.3",
    "camelcase-keys": "10.0.2",
    "croner": "9.1.0",
    "date-fns": "4.1.0",
    "discord-api-types": "0.38.41",
    "discord-fmt": "1.0.1",
    "dressed": "1.10.2-rc.2",
    "elysia": "1.4.27",
    "http-status-codes": "2.3.0",
    "keyv": "5.6.0",
    "ky": "1.14.3",
    "kysely": "0.28.11",
    "lru-cache": "11.2.6",
    "openapi-typescript": "7.13.0",
    "p-limit": "7.3.0",
    "pg": "8.20.0",
    "pino": "10.3.1",
    "pino-loki": "3.0.0",
    "pino-pretty": "13.1.3",
    "pino-std-serializers": "7.1.0",
    "react": "19.2.4"
  },
  "devDependencies": {
    "@types/pg": "8.18.0",
    "@types/react": "19.2.14"
  }
}
